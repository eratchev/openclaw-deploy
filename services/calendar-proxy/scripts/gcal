#!/usr/bin/env python3
"""gcal — CLI for the calendar-proxy service.

Usage:
  gcal create  --title TITLE --start ISO --end ISO --mode (execute|dry_run|needs_confirmation)
               [--calendar-id ID] [--description TEXT] [--rrule RULE] [--idem-key KEY]
  gcal list    --from ISO --to ISO [--calendar-id ID]
  gcal delete  --event-id ID --mode (execute|dry_run|needs_confirmation) [--calendar-id ID]
  gcal avail   --from ISO --to ISO --minutes N
  gcal health
"""
import json
import sys
import urllib.request
import urllib.error

BASE_URL = "http://calendar-proxy:8080"


def _call(tool: str, args: dict) -> dict:
    payload = json.dumps({"tool": tool, "args": args}).encode()
    req = urllib.request.Request(
        f"{BASE_URL}/call",
        data=payload,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            return json.load(resp)
    except urllib.error.HTTPError as e:
        body = e.read().decode(errors="replace")
        try:
            return json.loads(body)
        except Exception:
            return {"error": f"HTTP {e.code}: {body}"}
    except Exception as e:
        return {"error": str(e)}


def _health() -> dict:
    req = urllib.request.Request(f"{BASE_URL}/health", method="GET")
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.load(resp)
    except Exception as e:
        return {"error": str(e)}


def _parse_flag(args: list[str], flag: str, default=None):
    """Return value following --flag, or default."""
    try:
        i = args.index(flag)
        return args[i + 1]
    except (ValueError, IndexError):
        return default


def main():
    argv = sys.argv[1:]
    if not argv or argv[0] in ("-h", "--help"):
        print(__doc__)
        sys.exit(0)

    cmd = argv[0]
    rest = argv[1:]

    if cmd == "health":
        result = _health()
    elif cmd == "create":
        title = _parse_flag(rest, "--title")
        start = _parse_flag(rest, "--start")
        end = _parse_flag(rest, "--end")
        mode = _parse_flag(rest, "--mode", "dry_run")
        if not (title and start and end):
            print("Error: --title, --start, and --end are required", file=sys.stderr)
            sys.exit(1)
        args = {"title": title, "start": start, "end": end, "execution_mode": mode,
                "calendar_id": _parse_flag(rest, "--calendar-id", "primary")}
        if _parse_flag(rest, "--description"):
            args["description"] = _parse_flag(rest, "--description")
        if _parse_flag(rest, "--rrule"):
            args["recurrence_rrule"] = _parse_flag(rest, "--rrule")
        if _parse_flag(rest, "--idem-key"):
            args["idempotency_key"] = _parse_flag(rest, "--idem-key")
        result = _call("create_event", args)
    elif cmd == "list":
        time_from = _parse_flag(rest, "--from")
        time_to = _parse_flag(rest, "--to")
        if not (time_from and time_to):
            print("Error: --from and --to are required", file=sys.stderr)
            sys.exit(1)
        result = _call("list_events", {
            "time_min": time_from,
            "time_max": time_to,
            "calendar_id": _parse_flag(rest, "--calendar-id", "primary"),
        })
    elif cmd == "delete":
        event_id = _parse_flag(rest, "--event-id")
        mode = _parse_flag(rest, "--mode", "dry_run")
        if not event_id:
            print("Error: --event-id is required", file=sys.stderr)
            sys.exit(1)
        result = _call("delete_event", {
            "event_id": event_id,
            "execution_mode": mode,
            "calendar_id": _parse_flag(rest, "--calendar-id", "primary"),
        })
    elif cmd == "avail":
        time_from = _parse_flag(rest, "--from")
        time_to = _parse_flag(rest, "--to")
        minutes = _parse_flag(rest, "--minutes")
        if not (time_from and time_to and minutes):
            print("Error: --from, --to, and --minutes are required", file=sys.stderr)
            sys.exit(1)
        result = _call("check_availability", {
            "time_min": time_from,
            "time_max": time_to,
            "duration_minutes": int(minutes),
        })
    else:
        print(f"Unknown command: {cmd}", file=sys.stderr)
        print(__doc__, file=sys.stderr)
        sys.exit(1)

    print(json.dumps(result, indent=2))
    if isinstance(result, dict) and "error" in result:
        sys.exit(1)


if __name__ == "__main__":
    main()
